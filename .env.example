# ============================================================
# Intelligent Rental Hunter – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Email ---
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_PRIMARY=primary_recipient@gmail.com
EMAIL_SECONDARY=secondary_recipient@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Optional: Google Maps API (for commute scoring) ---
GOOGLE_MAPS_API_KEY=

# --- Optional: OpenAI API (for AI scam detection) ---
OPENAI_API_KEY=

# --- Destinations for commute calculation ---
COMMUTE_DESTINATION_1=1 Rue de la Réunion, 75020 Paris  # École 42
COMMUTE_DESTINATION_2=Créteil, 94000  # Créteil center

# --- Scheduler ---
# Interval in hours between email sends (default: 3)
EMAIL_INTERVAL_HOURS=3
